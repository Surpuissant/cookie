<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cookie Clicker</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="icon" type="image/png" href="/images/icon.png">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;700&display=swap" rel="stylesheet">
</head>
<body>
    <header class="top-bar">
        <div class="brand">
            <h1>Cookie Clicker Supuissant</h1>
        </div>
        <div class="user-info">
            <span>🍪 <strong><%= user %></strong></span>
            <a href="/logout" class="btn-logout">Déconnexion</a>
        </div>
    </header>

    <div class="game-container">
        <div class="mobile-stats-bar">
            <strong id="mobile-cookie-count">0</strong>
            <span>cookies</span>
            <span id="mobile-cps-display">par seconde : 0.0</span>
        </div>

        <!-- Panel 1: Stats -->
        <div class="stats-panel">
            <h2 id="cookie-count">0</h2>
            <p>cookies</p>
            <div id="cps-display">par seconde : 0</div>

            <div class="shop-section gamified-summary">
                <h4>🏆 Empire sucré</h4>
                <div class="score-row">
                    <span>Constructions</span>
                    <strong id="total-buildings">0</strong>
                </div>
                <div class="progress-track">
                    <div id="buildings-fill" class="progress-fill"></div>
                </div>
                <div class="score-row">
                    <span>Améliorations</span>
                    <strong id="total-upgrades">0</strong>
                </div>
                <div class="progress-track">
                    <div id="upgrades-fill" class="progress-fill alt"></div>
                </div>
                <p id="prestige-badge" class="prestige-badge">🥄 Débutant</p>
                <div class="building-visual-grid">
                    <div class="building-visual-card" id="visual-cursor_count">
                        <span class="building-emoji">🖱️</span>
                        <span class="building-name">Curseur</span>
                        <strong class="building-count">0</strong>
                    </div>
                    <div class="building-visual-card" id="visual-grandma_count">
                        <span class="building-emoji">👵</span>
                        <span class="building-name">Grand-mère</span>
                        <strong class="building-count">0</strong>
                    </div>
                    <div class="building-visual-card" id="visual-farm_count">
                        <span class="building-emoji">🌾</span>
                        <span class="building-name">Ferme</span>
                        <strong class="building-count">0</strong>
                    </div>
                    <div class="building-visual-card" id="visual-mine_count">
                        <span class="building-emoji">⛏️</span>
                        <span class="building-name">Mine</span>
                        <strong class="building-count">0</strong>
                    </div>
                </div>
            </div>
        </div>

        <!-- Panel 2: Cookie Central -->
        <div class="cookie-panel">
            <div class="vignette"></div>
            <div class="cookie-wrapper">
                <div class="shine-halo"></div>
                <div id="cursor-container" class="cursor-container"></div>
                <img src="/images/cookie.png" id="main-cookie" alt="Cookie">
            </div>
        </div>

        <!-- Panel 3: Store -->
        <div class="upgrades-panel">
            <h3 id="shop-title">Boutique</h3>
            
            <div class="shop-section">
                <h4>✨ Améliorations</h4>
                <div class="upgrade-icons-grid">
                    <div class="upgrade-item powerup-card icon-upgrade-card" id="upgrade-click" data-buy-target="buy-click" tabindex="0" role="button" aria-label="Acheter Mitaines de cuisine">
                        <div class="upgrade-icon">🖐️</div>
                        <div class="upgrade-hover-tooltip">
                            <h4>Mitaines de cuisine (Lvl <span id="click-level">1</span>)</h4>
                            <p>Augmente la force de chaque clic.</p>
                            <p>Coût : <span id="click-cost">15</span> 🍪</p>
                        </div>
                        <button id="buy-click" class="btn-buy sr-only">Acheter</button>
                    </div>

                    <div class="upgrade-item powerup-card icon-upgrade-card" id="upgrade-click-mult" data-buy-target="buy-click-mult" tabindex="0" role="button" aria-label="Acheter Crème pour les mains">
                        <div class="upgrade-icon">🧤</div>
                        <div class="upgrade-hover-tooltip">
                            <h4>Crème pour les mains</h4>
                            <p>Double les cookies gagnés par clic.</p>
                            <p>Coût : <span id="click-mult-cost">500</span> 🍪</p>
                        </div>
                        <button id="buy-click-mult" class="btn-buy sr-only">Acheter</button>
                    </div>

                    <div class="upgrade-item powerup-card icon-upgrade-card" id="upgrade-prod-mult" data-buy-target="buy-prod-mult" tabindex="0" role="button" aria-label="Acheter Rouleau à pâtisserie">
                        <div class="upgrade-icon">🪵</div>
                        <div class="upgrade-hover-tooltip">
                            <h4>Rouleau à pâtisserie</h4>
                            <p>Double la production de toutes les constructions.</p>
                            <p>Coût : <span id="prod-mult-cost">1000</span> 🍪</p>
                        </div>
                        <button id="buy-prod-mult" class="btn-buy sr-only">Acheter</button>
                    </div>
                </div>
            </div>

            <div class="shop-section">
                <h4>🏗️ Constructions</h4>
                <div class="upgrade-item building-card">
                    <div class="upgrade-info" id="building-cursor_count">
                        <h4>Curseur</h4>
                        <p>"Clique automatiquement toutes les 10 secondes."</p>
                        <p>• chaque curseur produit 0.4 cookies par seconde</p>
                        <p>Coût : 15 🍪</p>
                    </div>
                    <button id="buy-cursor_count" class="btn-buy">Acheter</button>
                </div>

                <div class="upgrade-item building-card">
                    <div class="upgrade-info" id="building-grandma_count">
                        <h4>Grand-mère</h4>
                        <p>"Une gentille grand-mère pour cuire plus de cookies"</p>
                        <p>• chaque grand-mère produit 2 cookies par seconde</p>
                        <p>Coût : 100 🍪</p>
                    </div>
                    <button id="buy-grandma_count" class="btn-buy">Acheter</button>
                </div>

                <div class="upgrade-item building-card">
                    <div class="upgrade-info" id="building-farm_count">
                        <h4>Ferme</h4>
                        <p>"Fait pousser des plants de cookies à partir de graines de cookies."</p>
                        <p>• chaque ferme produit 8 cookies par seconde</p>
                        <p>Coût : 1100 🍪</p>
                    </div>
                    <button id="buy-farm_count" class="btn-buy">Acheter</button>
                </div>

                <div class="upgrade-item building-card">
                    <div class="upgrade-info" id="building-mine_count">
                        <h4>Mine</h4>
                        <p>"Mine de la pâte à cookies et des pépites de chocolat."</p>
                        <p>• chaque mine produit 47 cookies par seconde</p>
                        <p>Coût : 12000 🍪</p>
                    </div>
                    <button id="buy-mine_count" class="btn-buy">Acheter</button>
                </div>
            </div>

        </div>
        </div>
    </main>

    <script src="/js/game.js" type="module"></script>
</body>
</html>
